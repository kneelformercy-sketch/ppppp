function Window:_selectTab(idx)
    for i, data in pairs(self._tabBtns) do
        local active = i == idx
        tw(data.btn, { BackgroundColor3 = active and Theme.TabActive or Theme.Sidebar, BackgroundTransparency = active and 0 or 1 }, 0.15)
        local lbl = data.btn:FindFirstChildOfClass("TextLabel")
        if lbl then tw(lbl, { TextColor3 = active and Theme.Text or Theme.TextDim }, 0.15) end
        local img = data.btn:FindFirstChildOfClass("ImageLabel")
        if img then tw(img, { ImageColor3 = active and Theme.Accent or Theme.TextMuted }, 0.15) end
        tw(data.ind, { BackgroundTransparency = active and 0 or 1 }, 0.15)
    end
    for i, page in pairs(self._tabPages) do
        page.Visible = i == idx
    end
    self._activeTab = idx
end

