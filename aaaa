local Section = {}
Section.__index = Section

local function makeElement(parent, layoutOrder)
    local el = New("Frame", {
        Size             = UDim2.new(1, 0, 0, EL_H),
        BackgroundColor3 = Theme.Element,
        BorderSizePixel  = 0,
        LayoutOrder      = layoutOrder,
        Parent           = parent,
    })
    Round(el, 5)
    return el
end

function Section:Toggle(opts)
    opts = opts or {}
    local label    = opts.Label    or "Toggle"
    local default  = opts.Default  ~= nil and opts.Default or false
    local callback = opts.Callback or function() end
    local state    = default

    local el = makeElement(self.List, self._order)
    self._order += 1
    el.ClipsDescendants = true

    New("TextLabel", {
        Size = UDim2.new(1, -52, 1, 0), Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1, Text = label, TextColor3 = Theme.Text,
        Font = Enum.Font.GothamMedium, TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6, Parent = el,
    })

    local track = New("Frame", {
        Size = UDim2.new(0, 34, 0, 18), Position = UDim2.new(1, -44, 0.5, -9),
        BackgroundColor3 = state and Theme.Toggle or Theme.Divider,
        BorderSizePixel = 0, ZIndex = 6, Parent = el,
    })
    Round(track, 9)
    Stroke(track, Theme.Border, 1)

    local thumb = New("Frame", {
        Size = UDim2.new(0, 12, 0, 12), Position = UDim2.new(0, state and 16 or 3, 0.5, -6),
        BackgroundColor3 = Color3.fromRGB(220, 220, 228), BorderSizePixel = 0, ZIndex = 7, Parent = track,
    })
    Round(thumb, 6)

    local btn = New("TextButton", {
        Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 8, Parent = el,
    })

    btn.MouseEnter:Connect(function() tw(el, { BackgroundColor3 = Theme.ElementHov }, 0.12) end)
    btn.MouseLeave:Connect(function() tw(el, { BackgroundColor3 = Theme.Element    }, 0.12) end)

    local function update(newState)
        state = newState
        tw(track, { BackgroundColor3 = state and Theme.Toggle or Theme.Divider }, 0.15)
        tw(thumb, { Position = UDim2.new(0, state and 16 or 3, 0.5, -6) }, 0.15)
        pcall(callback, state)
    end

    btn.MouseButton1Click:Connect(function() update(not state) end)
    Ripple(btn)

    return { SetValue = function(v) update(v) end, GetValue = function() return state end }
end

function Section:Slider(opts)
    opts = opts or {}
    local label    = opts.Label    or "Slider"
    local min      = opts.Min      or 0
    local max      = opts.Max      or 100
    local default  = opts.Default  ~= nil and opts.Default or min
    local suffix   = opts.Suffix   or ""
    local callback = opts.Callback or function() end
    local value    = math.clamp(default, min, max)

    local el = New("Frame", {
        Size = UDim2.new(1, 0, 0, EL_H + 10), BackgroundColor3 = Theme.Element,
        BorderSizePixel = 0, LayoutOrder = self._order, Parent = self.List,
    })
    Round(el, 5)
    self._order += 1

    New("TextLabel", {
        Size = UDim2.new(0.6, 0, 0, 20), Position = UDim2.new(0, 10, 0, 4),
        BackgroundTransparency = 1, Text = label, TextColor3 = Theme.Text,
        Font = Enum.Font.GothamMedium, TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6, Parent = el,
    })

    local valLbl = New("TextLabel", {
        Size = UDim2.new(0.4, -10, 0, 20), Position = UDim2.new(0.6, 0, 0, 4),
        BackgroundTransparency = 1, Text = tostring(value) .. suffix,
        TextColor3 = Theme.TextDim, Font = Enum.Font.GothamMedium, TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 6, Parent = el,
    })

    local track = New("Frame", {
        Size = UDim2.new(1, -20, 0, 4), Position = UDim2.new(0, 10, 0, 28),
        BackgroundColor3 = Theme.Divider, BorderSizePixel = 0, ZIndex = 6, Parent = el,
    })
    Round(track, 2)

    local fill = New("Frame", {
        Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = Theme.Slider, BorderSizePixel = 0, ZIndex = 7, Parent = track,
    })
    Round(fill, 2)

    local knob = New("Frame", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new((value - min) / (max - min), -6, 0.5, -6),
        BackgroundColor3 = Color3.fromRGB(220, 220, 235), BorderSizePixel = 0, ZIndex = 8, Parent = track,
    })
    Round(knob, 6)

    local hitbox = New("TextButton", {
        Size = UDim2.new(1, 0, 0, EL_H + 10), Position = UDim2.new(0, 0, -1, 0),
        BackgroundTransparency = 1, Text = "", ZIndex = 9, Parent = track,
    })

    local sliding = false
    local function setVal(x)
        local abs   = track.AbsoluteSize.X
        local rel   = math.clamp(x - track.AbsolutePosition.X, 0, abs)
        local pct   = rel / abs
        value = math.floor(min + (max - min) * pct + 0.5)
        fill.Size     = UDim2.new(pct, 0, 1, 0)
        knob.Position = UDim2.new(pct, -6, 0.5, -6)
        valLbl.Text   = tostring(value) .. suffix
        pcall(callback, value)
    end

    hitbox.MouseButton1Down:Connect(function() sliding = true end)
    UserInputService.InputChanged:Connect(function(i)
        if not sliding then return end
        if i.UserInputType == Enum.UserInputType.MouseMovement
        or i.UserInputType == Enum.UserInputType.Touch then
            setVal(i.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            sliding = false
        end
    end)
    hitbox.MouseButton1Down:Connect(function(x, y) setVal(UserInputService:GetMouseLocation().X) end)

    el.MouseEnter:Connect(function() tw(el, { BackgroundColor3 = Theme.ElementHov }, 0.12) end)
    el.MouseLeave:Connect(function() if not sliding then tw(el, { BackgroundColor3 = Theme.Element }, 0.12) end end)

    return {
        SetValue = function(v)
            value = math.clamp(v, min, max)
            local pct = (value - min) / (max - min)
            fill.Size     = UDim2.new(pct, 0, 1, 0)
            knob.Position = UDim2.new(pct, -6, 0.5, -6)
            valLbl.Text   = tostring(value) .. suffix
        end,
        GetValue = function() return value end
    }
end

function Section:Dropdown(opts)
    opts = opts or {}
    local label    = opts.Label    or "Dropdown"
    local options  = opts.Options  or {}
    local default  = opts.Default  or (options[1] or "")
    local callback = opts.Callback or function() end
    local selected = default
    local open     = false

    local ITEM_H = 28

    local el = New("Frame", {
        Size = UDim2.new(1, 0, 0, EL_H), BackgroundColor3 = Theme.Element,
        BorderSizePixel = 0, LayoutOrder = self._order, ClipsDescendants = false,
        ZIndex = 10, Parent = self.List,
    })
    Round(el, 5)
    self._order += 1

    New("TextLabel", {
        Size = UDim2.new(0.55, 0, 1, 0), Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1, Text = label, TextColor3 = Theme.Text,
        Font = Enum.Font.GothamMedium, TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 11, Parent = el,
    })

    local selLbl = New("TextLabel", {
        Size = UDim2.new(0.4, -28, 1, 0), Position = UDim2.new(0.55, 4, 0, 0),
        BackgroundTransparency = 1, Text = selected, TextColor3 = Theme.TextDim,
        Font = Enum.Font.GothamMedium, TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 11, Parent = el,
    })

    local arrow = New("ImageLabel", {
        Size = UDim2.new(0, 10, 0, 10), Position = UDim2.new(1, -16, 0.5, -5),
        BackgroundTransparency = 1, Image = "rbxassetid://10734907223",
        ImageColor3 = Theme.TextDim, ZIndex = 11, Parent = el,
    })

    local dropdown = New("Frame", {
        Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 1, 4),
        BackgroundColor3 = Theme.Section, BorderSizePixel = 0,
        ClipsDescendants = true, ZIndex = 20, Visible = false, Parent = el,
    })
    Round(dropdown, 5)
    Stroke(dropdown, Theme.Border, 1)

    local list = New("Frame", {
        Size = UDim2.new(1, 0, 0, #options * ITEM_H),
        BackgroundTransparency = 1, ZIndex = 21, Parent = dropdown,
    })
    New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Parent = list })

    local function pickOption(opt)
        selected = opt
        selLbl.Text = selected
        pcall(callback, selected)
        tw(dropdown, { Size = UDim2.new(1, 0, 0, 0) }, 0.18)
        task.delay(0.18, function() dropdown.Visible = false end)
        tw(arrow, { Rotation = 0 }, 0.18)
        open = false
    end

    for i, opt in ipairs(options) do
        local item = New("TextButton", {
            Size = UDim2.new(1, 0, 0, ITEM_H), BackgroundTransparency = 1,
            Text = "", LayoutOrder = i, ZIndex = 22, Parent = list,
        })
        New("TextLabel", {
            Size = UDim2.new(1, -16, 1, 0), Position = UDim2.new(0, 10, 0, 0),
            BackgroundTransparency = 1, Text = opt, TextColor3 = Theme.Text,
            Font = Enum.Font.Gotham, TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 23, Parent = item,
        })
        if i < #options then
            New("Frame", {
                Size = UDim2.new(1, -12, 0, 1), Position = UDim2.new(0, 6, 1, -1),
                BackgroundColor3 = Theme.Divider, BorderSizePixel = 0, ZIndex = 23, Parent = item,
            })
        end
        item.MouseEnter:Connect(function() item.BackgroundColor3 = Theme.TabHover; item.BackgroundTransparency = 0 end)
        item.MouseLeave:Connect(function() item.BackgroundColor3 = Theme.Section; item.BackgroundTransparency = 1 end)
        item.MouseButton1Click:Connect(function() pickOption(opt) end)
    end

    local btn = New("TextButton", {
        Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 12, Parent = el,
    })
    el.MouseEnter:Connect(function() tw(el, { BackgroundColor3 = Theme.ElementHov }, 0.12) end)
    el.MouseLeave:Connect(function() tw(el, { BackgroundColor3 = Theme.Element    }, 0.12) end)
    btn.MouseButton1Click:Connect(function()
        open = not open
        if open then
            dropdown.Visible = true
            dropdown.Size = UDim2.new(1, 0, 0, 0)
            tw(dropdown, { Size = UDim2.new(1, 0, 0, #options * ITEM_H) }, 0.2)
            tw(arrow, { Rotation = 180 }, 0.2)
        else
            tw(dropdown, { Size = UDim2.new(1, 0, 0, 0) }, 0.18)
            task.delay(0.18, function() dropdown.Visible = false end)
            tw(arrow, { Rotation = 0 }, 0.18)
        end
    end)

    return {
        SetValue  = function(v) selLbl.Text = v; selected = v end,
        GetValue  = function() return selected end,
        SetOptions = function(opts2)
            options = opts2
            for _, c in ipairs(list:GetChildren()) do
                if c:IsA("TextButton") then c:Destroy() end
            end
            list.Size = UDim2.new(1, 0, 0, #options * ITEM_H)
            for i, opt in ipairs(options) do
                local item = New("TextButton", {
                    Size = UDim2.new(1, 0, 0, ITEM_H), BackgroundTransparency = 1,
                    Text = opt, TextColor3 = Theme.Text, Font = Enum.Font.Gotham, TextSize = 11,
                    LayoutOrder = i, ZIndex = 22, Parent = list,
                })
                item.MouseButton1Click:Connect(function() pickOption(opt) end)
            end
        end
    }
end

function Section:Button(opts)
    opts = opts or {}
    local label    = opts.Label    or "Button"
    local desc     = opts.Desc     or nil
    local callback = opts.Callback or function() end

    local el = makeElement(self.List, self._order)
    self._order += 1
    el.ClipsDescendants = true

    local h = desc and EL_H + 14 or EL_H
    el.Size = UDim2.new(1, 0, 0, h)

    New("TextLabel", {
        Size = UDim2.new(1, -16, 0, 18), Position = UDim2.new(0, 10, 0, desc and 5 or 9),
        BackgroundTransparency = 1, Text = label, TextColor3 = Theme.Text,
        Font = Enum.Font.GothamMedium, TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6, Parent = el,
    })
    if desc then
        New("TextLabel", {
            Size = UDim2.new(1, -16, 0, 14), Position = UDim2.new(0, 10, 0, 22),
            BackgroundTransparency = 1, Text = desc, TextColor3 = Theme.TextDim,
            Font = Enum.Font.Gotham, TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6, Parent = el,
        })
    end

    local accent = New("Frame", {
        Size = UDim2.new(0, 2, 0.6, 0), Position = UDim2.new(0, 0, 0.2, 0),
        BackgroundColor3 = Theme.Accent, BorderSizePixel = 0, ZIndex = 6, Parent = el,
    })
    Round(accent, 1)

    local btn = New("TextButton", {
        Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", ZIndex = 7, Parent = el,
