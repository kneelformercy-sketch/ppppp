local function tw(obj, props, dur, style, dir)
    TweenService:Create(obj,
        TweenInfo.new(dur or 0.18, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out),
        props
    ):Play()
end

local function New(cls, props)
    local o = Instance.new(cls)
    for k, v in pairs(props) do
        if k ~= "Parent" then o[k] = v end
    end
    if props.Parent then o.Parent = props.Parent end
    return o
end

local function Round(obj, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6)
    c.Parent = obj
    return c
end

local function Stroke(obj, col, thick)
    local s = Instance.new("UIStroke")
    s.Color     = col or Theme.Border
    s.Thickness = thick or 1
    s.Parent    = obj
    return s
end

local function MakeDraggable(handle, frame)
    local CameraInput = nil
    pcall(function()
        CameraInput = require(LocalPlayer.PlayerScripts
            :WaitForChild("PlayerModule")
            :WaitForChild("CameraModule")
            :WaitForChild("CameraInput"))
    end)
    local dragging, dragStart, startPos, active = false, nil, nil, nil
    local function isClick(i)
        return i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch
    end
    handle.InputBegan:Connect(function(i)
        if not isClick(i) then return end
        dragging = true; active = i
        dragStart = i.Position; startPos = frame.Position
        if CameraInput then pcall(function() CameraInput.setInputEnabled(false) end) end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if not dragging then return end
        if IS_MOBILE and i ~= active then return end
        if not IS_MOBILE and i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local d = i.Position - dragStart
        frame.Position = UDim2.new(0, startPos.X.Offset + d.X, 0, startPos.Y.Offset + d.Y)
    end)
    UserInputService.InputEnded:Connect(function(i)
        if not dragging then return end
        if IS_MOBILE and i ~= active then return end
        dragging = false; active = nil
        if CameraInput then pcall(function() CameraInput.setInputEnabled(true) end) end
        local vp = workspace.CurrentCamera.ViewportSize
        local p  = frame.Position
        local cx = math.clamp(p.X.Offset, 0, vp.X - frame.AbsoluteSize.X)
        local cy = math.clamp(p.Y.Offset, 0, vp.Y - frame.AbsoluteSize.Y)
        tw(frame, { Position = UDim2.new(0, cx, 0, cy) }, 0.2)
    end)
end

local function Ripple(btn)
    btn.MouseButton1Click:Connect(function()
        local dot = New("Frame", {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0.5, 0.5),
            BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            BackgroundTransparency = 0.82,
            ZIndex = btn.ZIndex + 10,
            Parent = btn,
        })
        Round(dot, 100)
        tw(dot, { Size = UDim2.new(1.8, 0, 1.8, 0), BackgroundTransparency = 1 }, 0.4, Enum.EasingStyle.Quint)
        task.delay(0.4, function() dot:Destroy() end)
    end)
end

-- ─── Element base height ─────────────────────────────────────
local EL_H  = 36
local SEC_G = 6   -- gap between elements in a section
local PAD   = 10  -- section inner padding

