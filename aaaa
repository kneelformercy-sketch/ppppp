    })
    New("Frame", {
        Size = UDim2.new(1, -16, 0, 1), Position = UDim2.new(0, 8, 0, 0),
        BackgroundColor3 = Theme.Divider, BorderSizePixel = 0, ZIndex = 4, Parent = playerCard,
    })
    local avatar = New("ImageLabel", {
        Size = UDim2.new(0, 26, 0, 26), Position = UDim2.new(0, 8, 0.5, -13),
        BackgroundColor3 = Theme.Element, BorderSizePixel = 0, ZIndex = 5, Parent = playerCard,
    })
    Round(avatar, 6)
    task.spawn(function()
        local ok, url = pcall(function()
            return Players:GetUserThumbnailAsync(LocalPlayer.UserId,
                Enum.ThumbnailType.AvatarBust, Enum.ThumbnailSize.Size150x150)
        end)
        if ok and url then avatar.Image = url end
    end)
    New("TextLabel", {
        Size = UDim2.new(1, -50, 0, 14), Position = UDim2.new(0, 40, 0, 8),
        BackgroundTransparency = 1, Text = LocalPlayer.DisplayName,
        TextColor3 = Theme.Text, Font = Enum.Font.GothamMedium, TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd,
        ZIndex = 5, Parent = playerCard,
    })
    New("TextLabel", {
        Size = UDim2.new(1, -50, 0, 12), Position = UDim2.new(0, 40, 0, 24),
        BackgroundTransparency = 1, Text = "@" .. LocalPlayer.Name,
        TextColor3 = Theme.TextMuted, Font = Enum.Font.Gotham, TextSize = 9,
        TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd,
        ZIndex = 5, Parent = playerCard,
    })

    -- content area
    local content = New("Frame", {
        Size = UDim2.new(1, -SB_W, 1, -HDR_H),
        Position = UDim2.new(0, SB_W, 0, HDR_H),
        BackgroundTransparency = 1, ZIndex = 3, Parent = win,
    })
    local pages = New("Frame", {
        Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, ZIndex = 3, Parent = content,
    })

    -- open animation
    tw(overlay, { BackgroundTransparency = 0.6 }, 0.3)
    tw(blur, { Size = 16 }, 0.3)
    win.Size = UDim2.new(0, W_W, 0, 0)
    tw(win, { Size = UDim2.new(0, W_W, 0, W_H) }, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    MakeDraggable(header, win)

    -- toggle key
    UserInputService.InputBegan:Connect(function(i, gpe)
        if gpe then return end
        if i.KeyCode == key then
            win.Visible = not win.Visible
        end
    end)

    local w = {}
    setmetatable(w, Window)
    w._tabList   = tabList
    w._pages     = pages
    w._tabBtns   = {}
    w._tabPages  = {}
    w._tabCount  = 0
    w._activeTab = -1

    return w
end

-- Notification system
function Lib:Notify(opts)
    opts = opts or {}
    local title    = opts.Title    or ""
    local message  = opts.Message  or ""
    local duration = opts.Duration or 4
    local ntype    = opts.Type     or "info"

    local sg = CoreGui:FindFirstChild("AscendLib")
    if not sg then return end

    local color = ntype == "success" and Theme.Success
               or ntype == "error"   and Theme.Error
               or ntype == "warning" and Theme.Warning
               or Theme.Accent

    local holder = sg:FindFirstChild("_notifs") or New("Frame", {
        Name = "_notifs", Size = UDim2.new(0, 260, 1, 0),
        Position = UDim2.new(1, -270, 0, 0),
        BackgroundTransparency = 1, ZIndex = 100, Parent = sg,
    })
    if not sg:FindFirstChild("_notifs") then
        New("UIListLayout", {
            SortOrder = Enum.SortOrder.LayoutOrder,
            VerticalAlignment = Enum.VerticalAlignment.Bottom,
            Padding = UDim.new(0, 6), Parent = holder,
        })
        New("UIPadding", { PaddingBottom = UDim.new(0, 12), Parent = holder })
    end

    local card = New("Frame", {
        Size = UDim2.new(1, 0, 0, 0), BackgroundColor3 = Theme.Section,
        BorderSizePixel = 0, ClipsDescendants = true, ZIndex = 101,
        Parent = holder,
    })
    Round(card, 6)
    Stroke(card, Theme.Border, 1)

    local accent = New("Frame", {
        Size = UDim2.new(0, 3, 1, 0), BackgroundColor3 = color,
        BorderSizePixel = 0, ZIndex = 102, Parent = card,
    })
    Round(accent, 2)

    New("TextLabel", {
        Size = UDim2.new(1, -16, 0, 18), Position = UDim2.new(0, 12, 0, 8),
        BackgroundTransparency = 1, Text = title, TextColor3 = Theme.Text,
        Font = Enum.Font.GothamBold, TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 102, Parent = card,
    })
    New("TextLabel", {
        Size = UDim2.new(1, -16, 0, 28), Position = UDim2.new(0, 12, 0, 26),
        BackgroundTransparency = 1, Text = message, TextColor3 = Theme.TextDim,
        Font = Enum.Font.Gotham, TextSize = 11, TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 102, Parent = card,
    })

    tw(card, { Size = UDim2.new(1, 0, 0, 64) }, 0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    task.delay(duration, function()
        tw(card, { Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1 }, 0.2)
        task.delay(0.22, function() card:Destroy() end)
    end)
end

return Lib
