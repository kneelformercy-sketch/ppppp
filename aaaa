function Section:Keybind(opts)
    opts = opts or {}
    local label    = opts.Label    or "Keybind"
    local default  = opts.Default  or Enum.KeyCode.Unknown
    local onBind   = opts.OnBind   or function() end
    local onPress  = opts.OnPress  or opts.Callback or function() end
    local current  = default
    local listening = false

    local el = makeElement(self.List, self._order)
    self._order += 1
    el.ClipsDescendants = true

    New("TextLabel", {
        Size = UDim2.new(1, -80, 1, 0), Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1, Text = label, TextColor3 = Theme.Text,
        Font = Enum.Font.GothamMedium, TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6, Parent = el,
    })

    local badge = New("TextButton", {
        Size = UDim2.new(0, 66, 0, 22), Position = UDim2.new(1, -74, 0.5, -11),
        BackgroundColor3 = Theme.Section, Text = current == Enum.KeyCode.Unknown and "None" or current.Name,
        TextColor3 = Theme.TextDim, Font = Enum.Font.GothamMedium, TextSize = 10,
        AutoButtonColor = false, ZIndex = 6, Parent = el,
    })
    Round(badge, 4)
    local badgeStroke = Stroke(badge, Theme.Border, 1)

    local function setListening(v)
        listening = v
        if v then
            badge.Text = "press key"
            badge.TextColor3 = Theme.Accent
            tw(badgeStroke, { Color = Theme.Accent }, 0.12)
        else
            badge.TextColor3 = Theme.TextDim
            tw(badgeStroke, { Color = Theme.Border }, 0.12)
        end
    end

    badge.MouseButton1Click:Connect(function()
        setListening(not listening)
    end)
    el.MouseEnter:Connect(function() tw(el, { BackgroundColor3 = Theme.ElementHov }, 0.12) end)
    el.MouseLeave:Connect(function() tw(el, { BackgroundColor3 = Theme.Element    }, 0.12) end)

    UserInputService.InputBegan:Connect(function(i, gpe)
        if gpe then return end
        if listening then
            if i.UserInputType == Enum.UserInputType.Keyboard then
                if i.KeyCode == Enum.KeyCode.Escape then
                    setListening(false)
                    badge.Text = current == Enum.KeyCode.Unknown and "None" or current.Name
                    return
                end
                current = i.KeyCode
                badge.Text = current.Name
                setListening(false)
                pcall(onBind, current)
            end
        else
            if i.KeyCode == current and current ~= Enum.KeyCode.Unknown then
                pcall(onPress, current)
            end
        end
    end)

    return {
        GetValue = function() return current end,
        SetValue = function(k) current = k; badge.Text = k.Name end,
    }
end

