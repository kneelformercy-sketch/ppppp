    Round(box_bg, 4)
    local boxStroke = Stroke(box_bg, Theme.Border, 1)

    local box = New("TextBox", {
        Size = UDim2.new(1, -10, 1, 0), Position = UDim2.new(0, 6, 0, 0),
        BackgroundTransparency = 1, Text = default,
        PlaceholderText = placeholder, PlaceholderColor3 = Theme.TextMuted,
